# ── AlpHUB Backend Environment ──────────────────────────────────────────────
# Kopyala: cp .env.example .env  →  kendi yollarınla doldur.
# Backend restart gerektirir.

# ── Venv ─────────────────────────────────────────────────────────────────────
# Python sanal ortamı — pip install -r requirements.txt ile oluştur.
VENV_PATH=C:\path\to\your\venv

# ── Model kök dizini ──────────────────────────────────────────────────────────
MODEL_ROOT=C:\path\to\your\models

# ── Whisper (faster-whisper) ──────────────────────────────────────────────────
WHISPER_MODEL_DIR=C:\path\to\your\models\whisper
# Kullanılabilir: tiny · base · small · medium · large-v3
WHISPER_DEFAULT_MODEL=medium

# ── Kokoro (TTS) ──────────────────────────────────────────────────────────────
KOKORO_MODEL_DIR=C:\path\to\your\models\kokoro

# ── RVC (voice cloning) ───────────────────────────────────────────────────────
RVC_VOICE_DIR=C:\path\to\your\models\rvc\voices

# ── Demucs ────────────────────────────────────────────────────────────────────
# Demucs checkpoint'leri buraya indirilir (TORCH_HOME env var).
TORCH_HOME=C:\path\to\your\models\demucs

# ── Ideogram 4 (local inference) ─────────────────────────────────────────────
# NF4 pre-quantized model klasörü. diffusers 0.39.0.dev0 gerektirir.
IDEOGRAM_MODEL_PATH=C:\path\to\your\models\ideogram4-nf4

# ── Image Gen app launchers ───────────────────────────────────────────────────
# Kurulu değilse boş bırak veya satırı sil — launch butonu devre dışı olur.
FOOOCUS_PATH=C:\path\to\Fooocus\run.bat
COMFYUI_PATH=C:\path\to\ComfyUI\run.bat
FORGE_PATH=C:\path\to\Forge\webui.bat

# ── Output varsayılan ─────────────────────────────────────────────────────────
DEFAULT_OUTPUT_DIR=C:\AlpHUB-Output

# ── Backend ───────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
